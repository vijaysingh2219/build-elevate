{
  "name": "@workspace/auth",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./dist/server.js"
    },
    "./next-handlers": {
      "types": "./src/next-handlers.ts",
      "import": "./src/next-handlers.ts",
      "default": "./dist/next-handlers.js"
    },
    "./node-handlers": {
      "types": "./src/node-handlers.ts",
      "import": "./src/node-handlers.ts",
      "default": "./dist/node-handlers.js"
    }
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules",
    "dev": "tsc --build --watch",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "prettier": "@workspace/prettier-config",
  "dependencies": {
    "@t3-oss/env-nextjs": "catalog:core",
    "@workspace/db": "workspace:*",
    "@workspace/email": "workspace:*",
    "@workspace/rate-limit": "workspace:*",
    "better-auth": "catalog:core",
    "dotenv": "catalog:core",
    "zod": "catalog:core"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/prettier-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "catalog:dev"
  }
}