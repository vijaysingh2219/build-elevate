{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .next .turbo node_modules",
    "dev": "next dev --turbopack",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "prettier": "@workspace/prettier-config",
  "dependencies": {
    "@hookform/resolvers": "catalog:web",
    "@t3-oss/env-nextjs": "catalog:core",
    "@tanstack/react-query": "catalog:web",
    "@types/qrcode": "catalog:web",
    "@workspace/auth": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/ui": "workspace:*",
    "@workspace/utils": "workspace:*",
    "lucide-react": "catalog:web",
    "next": "catalog:web",
    "next-themes": "catalog:web",
    "pg": "catalog:core",
    "qrcode": "catalog:web",
    "react": "catalog:core",
    "react-dom": "catalog:core",
    "react-hook-form": "catalog:web",
    "sonner": "catalog:web",
    "zod": "catalog:core"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "catalog:dev",
    "@testing-library/react": "catalog:dev",
    "@testing-library/user-event": "catalog:dev",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:core",
    "@types/react-dom": "catalog:core",
    "@vitejs/plugin-react": "catalog:dev",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/prettier-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@workspace/vitest-presets": "workspace:*",
    "eslint": "catalog:eslint",
    "jsdom": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
